# SMTP Localweb — copie para .env e preencha com suas credenciais
SMTP_HOST=smtp.localweb.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@seudominio.com.br
SMTP_PASS=sua-senha
SMTP_FROM="Site Grupo Alvim" <seu-email@seudominio.com.br>
SMTP_TO=contato@grupoalvim.com.br

# Porta do servidor (opcional)
PORT=3000
